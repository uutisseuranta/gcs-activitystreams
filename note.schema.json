{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ActivityStreams 2.0 Note",
  "description": "Edustaa lyhyttä tekstikommenttia tai uutisartikkelin vastausviestiä.",
  "type": "object",
  "properties": {
    "@context": {
      "type": "string",
      "description": "JSON-LD konteksti, tyypillisesti https://www.w3.org/ns/activitystreams"
    },
    "type": {
      "type": "string",
      "description": "Objektin tyyppi, arvon on oltava 'Note'"
    },
    "id": {
      "type": "string",
      "description": "Kommentin yksikäsitteinen tunniste (IRI/URI)"
    },
    "content": {
      "type": "string",
      "description": "Kommentin leipäteksti HTML- tai plain text -muodossa"
    },
    "published": {
      "type": "string",
      "description": "Julkaisuajankohta RFC 3339 -muodossa"
    },
    "attributedTo": {
      "type": "string",
      "description": "Kommentin kirjoittajan tunniste (esim. käyttäjän sub-id)"
    },
    "inReplyTo": {
      "type": "string",
      "description": "Pääartikkelin tai ylemmän kommentin tunniste (id/IRI), johon tämä viesti vastaa"
    }
  },
  "required": ["@context", "type", "id", "content", "published", "attributedTo", "inReplyTo"]
}
